# Copy this file to `.env` and fill in your values, then run the scanner.
# `.env` is git-ignored — it never gets committed or pushed.

# From @BotFather on Telegram (see README step 2)
TELEGRAM_BOT_TOKEN=
# Your numeric chat id (see README step 2)
TELEGRAM_CHAT_ID=

# Optional: from console.anthropic.com. Leave blank to use keyword matching
# instead of Claude decoding for FlyerTalk threads.
ANTHROPIC_API_KEY=
